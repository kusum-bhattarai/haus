{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://haus.local/schemas/layer2_profile.schema.json",
  "title": "Haus Layer 2 Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "session_id",
    "created_at",
    "source_payload",
    "aesthetic_profile",
    "pins",
    "cluster_summary",
    "floor_plan",
    "provenance",
    "warnings"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "profile_id": { "type": "string", "format": "uuid" },
    "session_id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "source_payload": { "type": "object" },
    "aesthetic_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "palette",
        "lighting",
        "density",
        "style_era",
        "dominant_colors",
        "mood_words",
        "pinterest_cluster_labels",
        "confidence"
      ],
      "properties": {
        "palette": { "type": "string", "enum": ["warm_neutral", "cool_neutral", "earthy", "monochrome", "bold"] },
        "lighting": { "type": "string", "enum": ["golden_hour", "soft_ambient", "bright_natural", "dramatic", "artificial"] },
        "density": { "type": "string", "enum": ["minimal", "balanced", "layered", "maximalist"] },
        "style_era": {
          "type": "string",
          "enum": ["japandi", "mid_century", "scandinavian", "coastal", "industrial", "maximalist", "traditional"]
        },
        "dominant_colors": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        },
        "mood_words": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "pinterest_cluster_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "pins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pin" }
    },
    "cluster_summary": {
      "type": "array",
      "items": { "$ref": "#/$defs/cluster" }
    },
    "floor_plan": { "$ref": "#/$defs/floor_plan" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pinterest", "models"],
      "properties": {
        "pinterest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "requested_limit", "returned_count", "actor_id"],
          "properties": {
            "provider": { "const": "apify" },
            "requested_limit": { "type": "integer", "minimum": 1 },
            "returned_count": { "type": "integer", "minimum": 0 },
            "actor_id": { "type": ["string", "null"] }
          }
        },
        "models": {
          "type": "object",
          "additionalProperties": false,
          "required": ["aesthetic_extraction", "floor_plan_parsing"],
          "properties": {
            "aesthetic_extraction": { "type": "string" },
            "floor_plan_parsing": { "type": "string" }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning", "error"] }
        }
      }
    }
  },
  "$defs": {
    "pin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pin_id",
        "source_url",
        "image_url",
        "title",
        "description",
        "save_count",
        "hashtags",
        "cluster_label",
        "selected_for_mood_board"
      ],
      "properties": {
        "pin_id": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "image_url": { "type": "string", "format": "uri" },
        "title": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "save_count": { "type": ["integer", "null"], "minimum": 0 },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "cluster_label": { "type": ["string", "null"] },
        "selected_for_mood_board": { "type": "boolean" }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "pin_ids", "visual_notes", "weight"],
      "properties": {
        "label": { "type": "string" },
        "pin_ids": { "type": "array", "items": { "type": "string" } },
        "visual_notes": { "type": "string" },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "floor_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rooms", "total_rooms", "layout_type", "confidence", "notes"],
      "properties": {
        "rooms": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/room" }
        },
        "total_rooms": { "type": "integer", "minimum": 1 },
        "layout_type": { "type": "string", "enum": ["open_plan", "traditional", "studio"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "notes": { "type": ["string", "null"] }
      }
    },
    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "room_id",
        "name",
        "room_type",
        "area_estimate",
        "measured_dimensions",
        "measured_unit",
        "windows",
        "natural_light",
        "adjoins",
        "generation_priority"
      ],
      "properties": {
        "room_id": { "type": "string" },
        "name": { "type": "string" },
        "room_type": {
          "type": "string",
          "enum": ["living_room", "bedroom", "kitchen", "bathroom", "office", "dining_room", "other"]
        },
        "area_estimate": { "type": "string", "enum": ["large", "medium", "small"] },
        "measured_dimensions": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["width", "length", "area"],
          "properties": {
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "length": { "type": "number", "exclusiveMinimum": 0 },
            "area": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "measured_unit": { "type": ["string", "null"], "enum": ["ft", "m", null] },
        "windows": { "type": "string" },
        "natural_light": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
        "adjoins": { "type": "array", "items": { "type": "string" } },
        "generation_priority": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
